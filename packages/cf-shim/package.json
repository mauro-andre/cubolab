{
    "name": "@cubolab/cf-shim",
    "version": "0.0.0",
    "private": true,
    "description": "Cloudflare API shim — implementa o subset de endpoints DNS usado por consumidores (PodCubo). Propaga mutações pro pebble-challtestsrv. Executa em container via cubolab up.",
    "type": "module",
    "main": "./dist/bin/cf-shim.js",
    "scripts": {
        "dev": "tsx src/bin/cf-shim.ts",
        "build": "tsc -p tsconfig.build.json",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "vitest run --passWithNoTests"
    },
    "engines": {
        "node": ">=22"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    },
    "dependencies": {
        "@cubolab/core": "^0.0.0",
        "@hono/node-server": "^2.0.0",
        "hono": "^4.12.14",
        "zod": "^4.3.6"
    }
}
