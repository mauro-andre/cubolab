{
    "name": "cubolab",
    "version": "0.0.0",
    "description": "CLI pra subir um sandbox local de ACME/DNS/Cloudflare pra testar PaaS self-hosted sem IP público.",
    "type": "module",
    "bin": {
        "cubolab": "./dist/bin/cubolab.js"
    },
    "files": [
        "dist",
        "src/assets"
    ],
    "scripts": {
        "dev": "tsx src/bin/cubolab.ts",
        "build": "tsc -p tsconfig.build.json && mkdir -p dist/assets && cp -r src/assets/* dist/assets/ && chmod +x dist/bin/cubolab.js",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest"
    },
    "engines": {
        "node": ">=22"
    },
    "dependencies": {
        "@cubolab/core": "^0.0.0",
        "@peculiar/x509": "^2.0.0",
        "commander": "^14.0.3",
        "execa": "^9.6.1",
        "picocolors": "^1.1.1",
        "reflect-metadata": "^0.2.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    }
}
